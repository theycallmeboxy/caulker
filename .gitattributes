# Normalize line endings: Git stores LF, checks out native on each platform.
* text=auto

# Scripts that must stay LF even on Windows checkouts
*.sh text eol=lf
gradlew text eol=lf

# Windows batch scripts stay CRLF
*.bat text eol=crlf

# Binary files — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.jar binary
*.keystore binary
*.jks binary
